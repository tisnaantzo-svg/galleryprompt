      tags: ['Nature', 'AI'],
      prompt: 'Mount Bromo at dawn, sea of clouds below crater rim, dramatic volcanic landscape East Java Indonesia, warm golden first light, silhouette of local farmers on horseback, ethereal misty atmosphere, wide angle landscape photography, epic scale, National Geographic style, ultra detailed, 8k --ar 16:9 --style raw'
    },
    {
      id: 9,
      category: 'abstract',
      title: 'Neon Geometry Burst',
      tool: 'Flux Pro 1.1',
      img: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=600&q=80',
      tags: ['Abstract', 'AI'],
      prompt: 'Abstract digital art, exploding geometric shapes, neon color spectrum on deep black background, mathematical precision, sacred geometry patterns, glowing edges with lens flare, cyberpunk palette cyan magenta yellow, motion blur, high energy composition, cover art aesthetic, 4k resolution --ar 1:1'
    },
    {
      id: 10,
      category: 'portrait',
      title: 'Wayang Shadow Portrait',
      tool: 'Ideogram v2',
      img: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80',
      tags: ['Portrait', 'AI'],
      prompt: 'Dramatic portrait inspired by Indonesian wayang shadow puppet aesthetics, man in profile with strong geometric jawline, dramatic side lighting creating sharp shadows, traditional Javanese batik fabric as background, high contrast black and white with selective red accent color, artistic cultural fusion portrait --ar 4:5'
    },
    {
      id: 11,
      category: 'travel',
      title: 'Sumatra Jungle Poster',
      tool: 'Midjourney v6.1',
      img: 'https://images.unsplash.com/photo-1588392382834-a891154bca4d?w=600&q=80',
      tags: ['Travel Poster', 'AI'],
      prompt: 'Vintage adventure travel poster of Sumatra jungle, orangutan in dense rainforest canopy, lush tropical greens, retro 1960s poster design style, limited color palette, bold typography "WILD SUMATRA", screen print texture, conservation message, artistic illustration style, warm earthy tones --ar 2:3'
    },
    {
      id: 12,
      category: 'nature',
      title: 'Komodo Dragon Dusk',
      tool: 'Adobe Firefly',
      img: 'https://images.unsplash.com/photo-1546182990-dffeafbe841d?w=600&q=80',
      tags: ['Nature', 'AI'],
      prompt: 'Komodo dragon on rocky hillside at dusk, golden backlight creating dramatic silhouette, Komodo island Indonesia background, wildlife photography aesthetic, telephoto compression, dust particles visible in golden light, epic prehistoric atmosphere, David Attenborough documentary feel, cinematic wide shot --ar 16:9 --style raw'
    }
  ];

  // ── RENDER GRID ──
  let activeFilter = 'all';
  const grid = document.getElementById('galleryGrid');

  function renderCards(filter) {
    const filtered = filter === 'all' ? items : items.filter(i => i.category === filter);
    grid.innerHTML = '';
    filtered.forEach((item, idx) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.style.animationDelay = `${idx * 0.06}s`;
      card.dataset.id = item.id;
      card.innerHTML = `
        <div class="card-img-wrap">
          <img src="${item.img}" alt="${item.title}" loading="lazy" />
          <div class="card-overlay">
            <span class="copy-hint">👁 Lihat Prompt</span>
          </div>
        </div>
        <div class="card-body">
          <div class="card-tags">
            ${item.tags.map(t => `<span class="tag ${t==='AI'?'ai':''}">${t}</span>`).join('')}
          </div>
          <div class="card-title">${item.title}</div>
          <div class="card-prompt">${item.prompt}</div>
          <div class="card-footer">
            <span class="card-tool">🛠 ${item.tool}</span>
            <button class="copy-btn" data-id="${item.id}">📋 Copy</button>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });

    // Card click → modal
    grid.querySelectorAll('.card').forEach(card => {
      card.addEventListener('click', (e) => {
        if (e.target.classList.contains('copy-btn')) return;
        openModal(parseInt(card.dataset.id));
      });
    });

    // Copy btn
    grid.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const item = items.find(i => i.id === parseInt(btn.dataset.id));
        if (item) copyToClipboard(item.prompt, btn);
      });
    });
  }

  renderCards('all');

  // ── FILTER ──
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter;
      renderCards(activeFilter);
    });
  });

  // ── MODAL ──
  const overlay = document.getElementById('modalOverlay');
  const modalImg = document.getElementById('modalImg');
  const modalTitle = document.getElementById('modalTitle');
  const modalPrompt = document.getElementById('modalPrompt');
  const modalTool = document.getElementById('modalTool');
  const modalTags = document.getElementById('modalTags');
  const btnCopyFull = document.getElementById('btnCopyFull');

  function openModal(id) {
    const item = items.find(i => i.id === id);
    if (!item) return;
    modalImg.src = item.img;
    modalImg.alt = item.title;
    modalTitle.textContent = item.title;
    modalPrompt.textContent = item.prompt;
    modalTool.textContent = `🛠 Dibuat dengan: ${item.tool}`;
    modalTags.innerHTML = item.tags.map(t => `<span class="tag ${t==='AI'?'ai':''}">${t}</span>`).join('');
    btnCopyFull.textContent = 'Copy Prompt';
    btnCopyFull.className = 'btn-copy-full';
    btnCopyFull.onclick = () => copyToClipboard(item.prompt, btnCopyFull, true);
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  document.getElementById('btnClose').addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  function closeModal() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  // ── COPY ──
  function copyToClipboard(text, btn, isModal = false) {
    navigator.clipboard.writeText(text).then(() => {
      if (isModal) {
        btn.textContent = '✓ Berhasil Disalin!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy Prompt';
          btn.classList.remove('copied');
        }, 2000);
      } else {
        btn.textContent = '✓ Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = '📋 Copy';
          btn.classList.remove('copied');
        }, 2000);
      }
      showToast();
    });
  }

  function showToast() {
    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
  }

  // ── COFFEE DROPDOWN ──
  const coffeeBtn = document.getElementById('coffeeBtn');
  const coffeeDropdown = document.getElementById('coffeeDropdown');
  coffeeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    coffeeBtn.classList.toggle('open');
    coffeeDropdown.classList.toggle('open');
  });
  document.addEventListener('click', () => {
    coffeeBtn.classList.remove('open');
    coffeeDropdown.classList.remove('open');
  });
</script>
</body>
</html>
